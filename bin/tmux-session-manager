#!/usr/bin/env bash

SEARCH_DIRS=("$HOME/repos" "$HOME/Code")
EXTRA_DIRS=("$HOME/.dots")

existing_sessions=$(tmux list-sessions -F "#S" 2>/dev/null)

dirs=$(
  {
    find "${SEARCH_DIRS[@]}" -mindepth 0 -maxdepth 1 -type d 2>/dev/null

    for dir in "${EXTRA_DIRS[@]}"; do
      [ -d "$dir" ] && printf '%s\n' "$dir"
    done
  } |
    grep -v "^$" |
    grep -vFxf <(tmux list-sessions -F '#{session_path}' 2>/dev/null) |
    LC_COLLATE=C sort -u
)

if [[ -n "${TMUX}" ]]; then
  current_session=$(tmux display-message -p '#S')
  combined=$(
    echo "$current_session"
    echo "$existing_sessions" | grep -vFx "$current_session"
    echo "$dirs"
  )
else
  combined=$(
    echo "$existing_sessions"
    echo "$dirs"
  )
fi

selected=$(echo "$combined" | grep -v "^$" | fzf --tmux top,99% --border none --preview '
    if tmux has-session -t {} 2>/dev/null; then
      tmux list-windows -t {} -F "#I: #W" 2>/dev/null
    else
      echo "New session: $(basename {})"
    fi
')

[ -z "$selected" ] && exit 0

session_name=$(basename "$selected" | tr . _)

if ! tmux has-session -t "$session_name" 2>/dev/null; then
  tmux new-session -ds "$session_name" -c "$selected"
fi

if [ -n "$TMUX" ]; then
  tmux switch-client -t "$session_name"
  exit 0
fi

tmux attach-session -t "$session_name"

# Session was closed, so rerun session manager
exec "$0" "$@"
